{
  "name": "testimonial-cms",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace @testimonial-cms/api\" \"npm run dev --workspace @testimonial-cms/web\"",
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3"
  },
  "overrides": {
    "glob": "^11.0.3",
    "lodash": "^4.17.22"
  },
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.5.0"
  }
}
